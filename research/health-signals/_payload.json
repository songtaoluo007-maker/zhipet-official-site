[{"data":1,"prerenderedAt":75},["ShallowReactive",2],{"research-detail-\u002Fresearch\u002Fhealth-signals":3,"research-related-\u002Fresearch\u002Fhealth-signals":63},{"id":4,"title":5,"body":6,"category":46,"description":47,"extension":48,"meta":49,"navigation":50,"order":51,"path":52,"publishedAt":53,"publishedLabel":54,"seo":55,"status":56,"stem":57,"tags":58,"__hash__":62},"research\u002Fresearch\u002Fhealth-signals.md","宠物不会说话，但健康会留下痕迹",{"type":7,"value":8,"toc":39},"minimark",[9,13,17,20,33,36],[10,11,12],"h2",{"id":12},"内容定位",[14,15,16],"p",{},"这篇文章用于解释知宠为什么强调连续观察。宠物不会用人类语言直接描述身体感受，但活动节律、睡眠片段、叫声变化、食欲记录和主人反馈都可能成为状态变化的线索。",[10,18,19],{"id":19},"待确认信息",[21,22,23,27,30],"ul",{},[24,25,26],"li",{},"正式发布日期：待项目方确认",[24,28,29],{},"引用资料来源：待项目方确认",[24,31,32],{},"可公开产品截图或样机图：待项目方确认",[10,34,35],{"id":35},"写作边界",[14,37,38],{},"文章只能讨论“可能变化”“趋势观察”和“建议关注”，不能把单次数据写成诊断结论，也不能替代执业兽医意见。",{"title":40,"searchDepth":41,"depth":41,"links":42},"",2,[43,44,45],{"id":12,"depth":41,"text":12},{"id":19,"depth":41,"text":19},{"id":35,"depth":41,"text":35},"健康洞察","从活动、休息、叫声和照护记录中观察宠物状态变化，帮助家庭建立更连续的健康意识。","md",{},true,1,"\u002Fresearch\u002Fhealth-signals",null,"发布日期待项目方确认",{"title":5,"description":47},"正文待项目方确认","research\u002Fhealth-signals",[59,60,61],"连续观察","健康趋势","家庭照护","2twCHsN2HD_A4SAvyehd1x2U2-wl-CEREZdgna2-zeE",[64,68,72],{"path":65,"title":66,"category":67},"\u002Fresearch\u002Fsafety-first","为什么先做防走失，再做健康管理","产品思考",{"path":69,"title":70,"category":71},"\u002Fresearch\u002Fai-state-boundary","AI 状态解释不是“翻译”","AI 与技术",{"path":73,"title":74,"category":46},"\u002Fresearch\u002Fcontinuous-observation","观察会骗人：连续数据为什么更重要",1783252592376]