[{"data":1,"prerenderedAt":75},["ShallowReactive",2],{"research-detail-\u002Fresearch\u002Fai-state-boundary":3,"research-related-\u002Fresearch\u002Fai-state-boundary":63},{"id":4,"title":5,"body":6,"category":46,"description":47,"extension":48,"meta":49,"navigation":50,"order":51,"path":52,"publishedAt":53,"publishedLabel":54,"seo":55,"status":56,"stem":57,"tags":58,"__hash__":62},"research\u002Fresearch\u002Fai-state-boundary.md","AI 状态解释不是“翻译”",{"type":7,"value":8,"toc":39},"minimark",[9,13,17,20,33,36],[10,11,12],"h2",{"id":12},"内容定位",[14,15,16],"p",{},"这篇文章用于明确 AI 宠物理解的边界。知宠可以围绕叫声、动作、场景和历史记录推测可能状态，但不能宣称逐字翻译宠物语言。",[10,18,19],{"id":19},"待确认信息",[21,22,23,27,30],"ul",{},[24,25,26],"li",{},"可公开算法说明：待项目方确认",[24,28,29],{},"展示样例与置信度口径：待项目方确认",[24,31,32],{},"用户反馈闭环：待项目方确认",[10,34,35],{"id":35},"写作边界",[14,37,38],{},"AI 判断必须保留“可能”“推测”“趋势”“风险提示”等概率表达，并展示依据和不确定性。",{"title":40,"searchDepth":41,"depth":41,"links":42},"",2,[43,44,45],{"id":12,"depth":41,"text":12},{"id":19,"depth":41,"text":19},{"id":35,"depth":41,"text":35},"AI 与技术","知宠的 AI 状态解释应提供依据、不确定性和建议观察，而不是把宠物语言逐字翻译成人话。","md",{},true,3,"\u002Fresearch\u002Fai-state-boundary",null,"发布日期待项目方确认",{"title":5,"description":47},"正文待项目方确认","research\u002Fai-state-boundary",[59,60,61],"AI 边界","状态解释","不确定性","qR-SkXDMlpvEOa2t08VuVuTUEo0nElzBQbdQAHPA1YE",[64,68,72],{"path":65,"title":66,"category":67},"\u002Fresearch\u002Fhealth-signals","宠物不会说话，但健康会留下痕迹","健康洞察",{"path":69,"title":70,"category":71},"\u002Fresearch\u002Fsafety-first","为什么先做防走失，再做健康管理","产品思考",{"path":73,"title":74,"category":67},"\u002Fresearch\u002Fcontinuous-observation","观察会骗人：连续数据为什么更重要",1783252591916]