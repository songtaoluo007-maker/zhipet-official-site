[{"data":1,"prerenderedAt":75},["ShallowReactive",2],{"research-detail-\u002Fresearch\u002Fcontinuous-observation":3,"research-related-\u002Fresearch\u002Fcontinuous-observation":63},{"id":4,"title":5,"body":6,"category":46,"description":47,"extension":48,"meta":49,"navigation":50,"order":51,"path":52,"publishedAt":53,"publishedLabel":54,"seo":55,"status":56,"stem":57,"tags":58,"__hash__":62},"research\u002Fresearch\u002Fcontinuous-observation.md","观察会骗人：连续数据为什么更重要",{"type":7,"value":8,"toc":39},"minimark",[9,13,17,20,33,36],[10,11,12],"h2",{"id":12},"内容定位",[14,15,16],"p",{},"这篇文章用于解释“连续记录”的价值。单次活跃、短暂叫唤或一次睡眠变化未必代表异常，长期趋势更适合帮助家庭判断是否需要继续观察或咨询专业人士。",[10,18,19],{"id":19},"待确认信息",[21,22,23,27,30],"ul",{},[24,25,26],"li",{},"数据采集频率：待项目方确认",[24,28,29],{},"记录字段与展示粒度：待项目方确认",[24,31,32],{},"异常提醒规则：待项目方确认",[10,34,35],{"id":35},"写作边界",[14,37,38],{},"不使用模型准确率、样本规模或研究结论，除非项目方提供可公开资料。",{"title":40,"searchDepth":41,"depth":41,"links":42},"",2,[43,44,45],{"id":12,"depth":41,"text":12},{"id":19,"depth":41,"text":19},{"id":35,"depth":41,"text":35},"健康洞察","单次观察容易受环境影响，连续记录更适合帮助主人识别习惯变化和异常趋势。","md",{},true,4,"\u002Fresearch\u002Fcontinuous-observation",null,"发布日期待项目方确认",{"title":5,"description":47},"正文待项目方确认","research\u002Fcontinuous-observation",[59,60,61],"连续数据","行为趋势","风险提示","YQdxndlq0tX7yA6UJVTCesn5vlNAK_A3LZsYAZ1vspU",[64,67,71],{"path":65,"title":66,"category":46},"\u002Fresearch\u002Fhealth-signals","宠物不会说话，但健康会留下痕迹",{"path":68,"title":69,"category":70},"\u002Fresearch\u002Fsafety-first","为什么先做防走失，再做健康管理","产品思考",{"path":72,"title":73,"category":74},"\u002Fresearch\u002Fai-state-boundary","AI 状态解释不是“翻译”","AI 与技术",1783474133235]