[{"data":1,"prerenderedAt":74},["ShallowReactive",2],{"research-detail-\u002Fresearch\u002Fsafety-first":3,"research-related-\u002Fresearch\u002Fsafety-first":62},{"id":4,"title":5,"body":6,"category":46,"description":47,"extension":48,"meta":49,"navigation":50,"order":41,"path":51,"publishedAt":52,"publishedLabel":53,"seo":54,"status":55,"stem":56,"tags":57,"__hash__":61},"research\u002Fresearch\u002Fsafety-first.md","为什么先做防走失，再做健康管理",{"type":7,"value":8,"toc":39},"minimark",[9,13,17,20,33,36],[10,11,12],"h2",{"id":12},"内容定位",[14,15,16],"p",{},"这篇文章用于说明产品路径：先让家庭愿意持续佩戴和使用，再逐步沉淀健康趋势、状态解释和照护建议。安全需求更容易被理解，也更适合作为设备与 App 的第一入口。",[10,18,19],{"id":19},"待确认信息",[21,22,23,27,30],"ul",{},[24,25,26],"li",{},"产品形态与安装方式：待项目方确认",[24,28,29],{},"定位、通信和提醒规则：待项目方确认",[24,31,32],{},"上线节奏：待项目方确认",[10,34,35],{"id":35},"写作边界",[14,37,38],{},"不声明未确认定位精度、续航、防护等级或量产状态。安全提醒只能写作规划方向或样机验证方向。",{"title":40,"searchDepth":41,"depth":41,"links":42},"",2,[43,44,45],{"id":12,"depth":41,"text":12},{"id":19,"depth":41,"text":19},{"id":35,"depth":41,"text":35},"产品思考","安全防走失是家庭养宠最直接的需求入口，也为长期健康记录建立稳定佩戴基础。","md",{},true,"\u002Fresearch\u002Fsafety-first",null,"发布日期待项目方确认",{"title":5,"description":47},"正文待项目方确认","research\u002Fsafety-first",[58,59,60],"安全防走失","产品路径","佩戴习惯","9pUrkP79eCRC5F13KxJNXPTsDjP60EEOi2zl5TM7byk",[63,67,71],{"path":64,"title":65,"category":66},"\u002Fresearch\u002Fhealth-signals","宠物不会说话，但健康会留下痕迹","健康洞察",{"path":68,"title":69,"category":70},"\u002Fresearch\u002Fai-state-boundary","AI 状态解释不是“翻译”","AI 与技术",{"path":72,"title":73,"category":66},"\u002Fresearch\u002Fcontinuous-observation","观察会骗人：连续数据为什么更重要",1783474133234]