NODE_ENV=production
HOST=127.0.0.1
PORT=3000

NUXT_APP_BASE_URL=/
NUXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN
NUXT_PUBLIC_FEEDBACK_ENABLED=false
NUXT_PRIVACY_POLICY_VERSION=2026-07-12
NUXT_TERMS_VERSION=2026-07-12

NUXT_PUBLIC_APP_DOWNLOAD_ENABLED=false
NUXT_PUBLIC_APP_DOWNLOAD_IOS_URL=
NUXT_PUBLIC_APP_DOWNLOAD_ANDROID_URL=
NUXT_PUBLIC_APP_DOWNLOAD_ALLOWED_HOSTS=apps.apple.com,testflight.apple.com
NUXT_PUBLIC_APP_DOWNLOAD_VERSION=
NUXT_PUBLIC_APP_DOWNLOAD_PUBLISHED_AT=
NUXT_PUBLIC_APP_DOWNLOAD_ANDROID_SHA256=

DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_PRIVATE_DB_HOST:5432/zhipet?schema=public&sslmode=require

MAIL_NOTIFICATION_TO=YOUR_NOTIFICATION_EMAIL
MAIL_ENABLED=false
SMTP_HOST=smtp.126.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=YOUR_SMTP_USER
SMTP_PASSWORD=YOUR_SMTP_CLIENT_AUTHORIZATION_CODE
MAIL_FROM=YOUR_SMTP_USER
