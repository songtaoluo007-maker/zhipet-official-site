  "dependencies": {
    "@nuxt/content": "^3.6.3",
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/image": "^1.11.0",
    "@prisma/client": "^6.19.3",
    "nodemailer": "^9.0.3",
    "nuxt": "^4.0.0",
    "sass": "^1.89.2",
    "valibot": "^1.4.2",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.7.0",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.53.1",
    "prettier": "^3.9.6",
    "prisma": "^7.9.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
