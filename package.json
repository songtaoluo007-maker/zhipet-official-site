{
  "name": "zhipet-official-site",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "nuxt build",
    "db:dev": "docker compose up -d database",
    "db:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:purge-expired": "node scripts/purge-expired-data.mjs",
    "db:studio": "prisma studio",
    "dev": "nuxt dev --host 127.0.0.1",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "mail:deliver": "node scripts/deliver-email-outbox.mjs",
