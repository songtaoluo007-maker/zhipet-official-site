{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "database: start",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "up", "-d", "database"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "database: stop",
      "type": "shell",
      "command": "docker",
      "args": ["compose", "down"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "zhipet: dev",
      "dependsOrder": "sequence",
      "dependsOn": ["database: start", "nuxt: dev"],
      "problemMatcher": []
    },
    {
      "label": "nuxt: dev",
      "type": "shell",
      "command": "C:\\Users\\Administrator\\nodejs\\pnpm.CMD",
      "args": ["dev", "--port", "3000"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "Path": "C:\\Users\\Administrator\\nodejs;${env:Path}",
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "nuxt",
        "pattern": {
          "regexp": "^\\s*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Nuxt.*$",
          "endsPattern": "^.*Local:.*http://127\\.0\\.0\\.1:3000/.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "nuxt: lint",
      "type": "shell",
      "command": "C:\\Users\\Administrator\\nodejs\\pnpm.CMD",
      "args": ["lint"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "Path": "C:\\Users\\Administrator\\nodejs;${env:Path}"
        }
      },
      "problemMatcher": "$eslint-stylish"
    },
    {
      "label": "nuxt: typecheck",
      "type": "shell",
      "command": "C:\\Users\\Administrator\\nodejs\\pnpm.CMD",
      "args": ["typecheck"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "Path": "C:\\Users\\Administrator\\nodejs;${env:Path}"
        }
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "nuxt: test",
      "type": "shell",
      "command": "C:\\Users\\Administrator\\nodejs\\pnpm.CMD",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "Path": "C:\\Users\\Administrator\\nodejs;${env:Path}"
        }
      },
      "problemMatcher": []
    }
  ]
}
