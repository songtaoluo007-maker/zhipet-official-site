# Production only: enable after the Nuxt server, database, HTTPS, backups and cleanup schedule are ready.
# NUXT_PUBLIC_FEEDBACK_ENABLED=true
# SMTP delivery is disabled by default. Use a provider-generated client authorization code,
# never the webmail login password. The web service only needs MAIL_NOTIFICATION_TO;
# SMTP credentials belong on the mail-delivery cron service.
MAIL_NOTIFICATION_TO=petSense@126.com
MAIL_ENABLED=false
SMTP_HOST=smtp.126.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=petSense@126.com
SMTP_PASSWORD=
MAIL_FROM=petSense@126.com
